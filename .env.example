# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to `.env.local` and fill in your values

# ============================================
# API CONFIGURATION
# ============================================
# This should point to your deployed backend on Render
# Format: https://your-backend-name.onrender.com
REACT_APP_BASE_URL=http://localhost:4000

# ============================================
# NOTE
# ============================================
# React only loads env variables prefixed with REACT_APP_
# After updating this file, restart the development server
