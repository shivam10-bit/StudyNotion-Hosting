# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URL=your_mongodb_connection_string_here

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a random string of at least 32 characters (use: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_min_32_chars_long_change_this

# ============================================
# CLOUDINARY (Image Upload Service)
# ============================================
# Get these from https://cloudinary.com/console
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# ============================================
# RAZORPAY (Payment Gateway)
# ============================================
# Get these from https://razorpay.com/developers/api
RAZORPAY_KEY=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_key_secret

# ============================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================
# For Gmail: Use App Password (not your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_USER=your_gmail_address@gmail.com
MAIL_PASS=your_16_character_gmail_app_password

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=8080
NODE_ENV=production

# ============================================
# FRONTEND URL (CORS Configuration)
# ============================================
# Update after Vercel deployment
FRONTEND_URL=http://localhost:3000